{
  "name": "system",
  "version": "1.0.0",
  "description": "task tracking",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:plugin": "OBSIDIAN_PLUGIN_DIR='/Users/dfedy/Library/Mobile Documents/iCloud~md~obsidian/Documents/vault/.obsidian/plugins/system-engine' node esbuild.config.mjs",
    "build": "OBSIDIAN_PLUGIN_DIR='/Users/dfedy/Library/Mobile Documents/iCloud~md~obsidian/Documents/vault/.obsidian/plugins/system-engine' node esbuild.config.mjs production",
    "parse:sessions": "SYSTEM_ENGINE_ROOT='/Users/dfedy/Library/Mobile Documents/iCloud~md~obsidian/Documents/vault/SYSTEM/.engine' tsx -r tsconfig-paths/register scripts/parseDailySessions.ts",
    "build:ticket-spent": "SYSTEM_ENGINE_ROOT='/Users/dfedy/Library/Mobile Documents/iCloud~md~obsidian/Documents/vault/SYSTEM/.engine' tsx -r tsconfig-paths/register scripts/buildTicketSpent.ts",
    "build:ticket-stats": "SYSTEM_ENGINE_ROOT='/Users/dfedy/Library/Mobile Documents/iCloud~md~obsidian/Documents/vault/SYSTEM/.engine' tsx -r tsconfig-paths/register scripts/buildTicketStats.ts",
    "build:sprint-summary": "SYSTEM_ENGINE_ROOT='/Users/dfedy/Library/Mobile Documents/iCloud~md~obsidian/Documents/vault/SYSTEM/.engine' tsx -r tsconfig-paths/register scripts/buildCurrentSprintSummary.ts",
    "build:dashboard": "SYSTEM_ENGINE_ROOT='/Users/dfedy/Library/Mobile Documents/iCloud~md~obsidian/Documents/vault/SYSTEM/.engine' tsx -r tsconfig-paths/register scripts/buildDashboard.ts",
    "build:burndown": "SYSTEM_ENGINE_ROOT='/Users/dfedy/Library/Mobile Documents/iCloud~md~obsidian/Documents/vault/SYSTEM/.engine' tsx -r tsconfig-paths/register scripts/buildBurndown.ts",
    "sync:spent": "SYSTEM_ENGINE_ROOT='/Users/dfedy/Library/Mobile Documents/iCloud~md~obsidian/Documents/vault/SYSTEM/.engine' tsx -r tsconfig-paths/register scripts/syncSpentToTickets.ts",
    "build:burndown-svg": "SYSTEM_ENGINE_ROOT='/Users/dfedy/Library/Mobile Documents/iCloud~md~obsidian/Documents/vault/SYSTEM/.engine' tsx -r tsconfig-paths/register scripts/buildBurndownSvg.ts",
    "build:burndown-excalidraw": "SYSTEM_ENGINE_ROOT='/Users/dfedy/Library/Mobile Documents/iCloud~md~obsidian/Documents/vault/SYSTEM/.engine' tsx -r tsconfig-paths/register scripts/buildBurndownExcalidraw.ts",
    "build:all": "npm run parse:sessions && npm run build:ticket-spent && npm run build:ticket-stats && npm run build:sprint-summary && npm run build:dashboard && npm run build:burndown && npm run build:burndown-excalidraw && npm run sync:spent"
  },
  "author": "Dearian",
  "license": "ISC",
  "devDependencies": {
    "esbuild": "^0.25.10",
    "@types/node": "^25.5.0",
    "jsdom": "^26.1.0",
    "obsidian": "^1.8.10",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "gray-matter": "^4.0.3"
  }
}
