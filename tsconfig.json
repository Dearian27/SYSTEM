{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": "./src",
    "paths": {
      "@/*": ["*"]
    },
    "strict": true,
    "noEmit": true,
    "types": ["node"],
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0"
  },
 
  
  "include": ["src/**/*.ts", "scripts/**/*.ts", "constants.ts"]
}