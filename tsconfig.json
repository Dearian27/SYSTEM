{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["DOM", "ES2022"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "strict": true,
    "noEmit": true,
    "types": ["node", "obsidian"],
    "skipLibCheck": true,
    "ignoreDeprecations": "5.0"
  },
 
  
  "include": [
    "main.ts",
    "src/**/*.ts",
    "scripts/**/*.ts",
    "tests/**/*.ts",
    "constants.ts"
  ]
}
